  "keyFeatures": [
    "Comprehensive LLM tracing with deep observability for calls, conversations, and agent activity",
    "Advanced evaluation with datasets, experiments, and LLM-as-a-judge metrics",
    "Production monitoring with scalable dashboards and online evaluation rules",
    "Agent optimization with dedicated SDK for prompt and agent enhancement",
    "Guardrails for safe and responsible AI implementation",
    "Extensive integrations with LangChain, OpenAI, Anthropic, LlamaIndex, and more",
    "Self-hosted and cloud deployment options",
    "Python and TypeScript SDKs with decorator-based tracing",
    "Automated hallucination detection and RAG assessment",
    "PyTest integration for CI/CD workflows"
  ],
  "publicApiSurface": [
    "opik.Opik - Main client class",
    "opik.track - Decorator for automatic tracing",
    "opik.Trace - Trace context manager",
    "opik.Span - Span context manager",
    "opik.Dataset - Dataset management",
    "opik.evaluate - Evaluation runner",
    "opik.configure - SDK configuration",
    "opik.AgentConfig - Agent configuration",
    "opik.Prompt - Prompt management",
    "opik.llm_unit - PyTest decorator",
    "Opik (TypeScript) - Main client class",
    "track (TypeScript) - Tracing decorator",
    "Dataset (TypeScript) - Dataset management",
    "evaluate (TypeScript) - Evaluation runner",
    "TracesAnnotationQueue - Annotation queue for traces",
    "ThreadsAnnotationQueue - Annotation queue for threads"
  ]
